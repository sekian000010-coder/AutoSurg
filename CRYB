    _G.blockDialog = false
    LogToConsole("[Surgery] Unloaded")
end

-- ===== HOOK UNTUK UI =====
addHook(function(type,name,value)

    if name == "surg_mode" then
        _G.surgMode = value
        if value then
            _G.surgTrain = false
            pcall(editValue, "surg_train", false)
        end
        growtopia.notify("Surg-E Mode " .. (value and "ON" or "OFF"))

    elseif name == "surg_train" then
        _G.surgTrain = value
        if value then
            _G.surgMode = false
            pcall(editValue, "surg_mode", false)
        end
        growtopia.notify("Train-E Mode " .. (value and "ON" or "OFF"))

    elseif name == "surg_legal" then
        _G.surgLegal = value
        growtopia.notify("Legal Brief " .. (value and "ON" or "OFF"))

    elseif name == "surg_start_toggle" then
        _G.surgStart = value
        if value then
            growtopia.notify("Auto Surgery Started")
        else
            growtopia.notify("Auto Surgery Paused")
        end

    elseif name == "surg_stop" then
        _G.surgStart = false
        pcall(editValue, "surg_start_toggle", false)
        growtopia.notify("Auto Surgery Stopped")
    end

end,"onValue")

