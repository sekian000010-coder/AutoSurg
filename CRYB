    while true do
        sleep(2000)
        pcall(editValue, "total_tools", "Tools Used: "..totalTools)
    end
end)

addHook(function(type, name, value)
    if name == "aleg_toggle" then
        Aleg = value
    elseif name == "mode_surg" then
        modeSurg = value
        if value then
            modeTrain = false
            pcall(editValue, "mode_train", false)
            growtopia.notify("Mode: Surg-E")
        end
    elseif name == "mode_train" then
        modeTrain = value
        if value then
            modeSurg = false
            pcall(editValue, "mode_surg", false)
            growtopia.notify("Mode: Train-E")
        end
    elseif name == "btn_start" then
        startMode = value
        if value then
            growtopia.notify("Auto Start: ON")
        else
            growtopia.notify("Auto Start: OFF")
        end
    end
end, "onValue")

runCoroutine(function()
    sleep(1000)
    growtopia.notify("Auto Surgery ready")
end)

applyHook()
